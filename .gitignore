# ── Python ────────────────────────────────────────────────
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
venv/
.venv/
envs/

# ── Large raw data and generated datasets (regenerable from the .mat) ──
*.mat
data/*.csv
experiments/**/data/*.csv

# ── Model weights and checkpoints (large; regenerable) ──
*.pt

# ── Archives ──
*.tgz
*.tar.gz

# ── HPC job logs (kept under logs/ or as job*.out/err) ──
# Ignore the log files but KEEP the logs/ directory itself (via logs/.gitkeep):
# Slurm opens --output logs/...%j.out at job launch, before the job script can
# mkdir it, so the dir must already exist after a fresh clone or the job dies
# instantly with no output.
job*.out
job*.err
logs/*
!logs/.gitkeep
*.sbatch.log

# Tracked on purpose: scripts, *.md, config.json, metrics.json, progress.csv,
# *_meta.json, search.csv/json, and figures (*.png/*.svg) so results + state
# travel with the repo for the next session.
